// freyaOMS — schéma de données
//
// Voir docs/DATABASE.md pour le raisonnement complet derrière chaque
// modèle. Résumé des règles qui ne sont pas évidentes en lisant juste
// les champs :
//   - `Order.channel` et `Order.isConfirmed` sont calculés à l'ingestion
//     (voir docs/SHOPIFY_SYNC.md) et dénormalisés ici pour que toutes les
//     requêtes d'insights puissent filtrer/grouper sans recalculer la
//     logique de tags à chaque fois.
//   - Tous les insights (vitesse de vente, jours de stock restant,
//     produits dormants) se filtrent sur `isConfirmed = true AND
//     cancelledAt IS NULL` et se bucketent sur `orderCreatedAt`
//     (la date de commande client, jamais une date de traitement).
//   - Un seul stock global par variante : pas de table par location.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderChannel {
  B2B
  B2C
}

enum SyncResource {
  PRODUCTS
  ORDERS
  FORECAST
}

enum ForecastScope {
  GLOBAL
  CATEGORY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum UserRole {
  ADMIN
  VIEWER
}

model Product {
  id        String @id @default(cuid())
  shopifyId BigInt @unique

  title       String
  vendor      String?
  productType String?
  status      String // Shopify: active | archived | draft

  shopifyCreatedAt DateTime
  shopifyUpdatedAt DateTime
  syncedAt         DateTime @default(now())

  variants Variant[]

  @@index([status])
}

model Variant {
  id        String @id @default(cuid())
  shopifyId BigInt @unique

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Shopify inventory_item_id — clé de jointure si on doit un jour
  // revenir aux inventory levels (ex: passage au multi-location).
  inventoryItemId BigInt @unique

  sku     String?
  barcode String?
  title   String

  // Dérivé à l'ingestion depuis le préfixe SKU (voir docs/SHOPIFY_SYNC.md,
  // section "Règle de dérivation : isBlackMarket") : true si ce SKU
  // représente une vente non déclarée ("au black"). C'est une dimension
  // distincte de Order.channel (B2B/B2C) : celle-ci est au niveau de la
  // commande, celle-là au niveau du SKU/variante.
  isBlackMarket Boolean @default(false)

  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  cost           Decimal? @db.Decimal(12, 2)

  // Dernière quantité connue (cache rapide pour les listes/tableaux).
  // La vérité historique vit dans InventorySnapshot.
  inventoryQuantity Int

  // Date de création côté Shopify — nécessaire pour ne pas sous-estimer la
  // vitesse de vente d'une variante récemment ajoutée (voir docs/INSIGHTS.md,
  // "Vitesse de vente : produits récemment ajoutés"). Nullable : les
  // variantes synchronisées avant l'introduction de ce champ (2026-07-18)
  // n'en ont pas tant que `npm run backfill:variant-created-at` n'a pas
  // tourné — en son absence, la vitesse de vente suppose prudemment que la
  // variante existe depuis le début de la fenêtre demandée (comportement
  // identique à avant ce correctif, jamais une erreur).
  shopifyCreatedAt DateTime?
  shopifyUpdatedAt DateTime
  syncedAt         DateTime @default(now())

  snapshots InventorySnapshot[]
  lineItems OrderLineItem[]

  @@index([sku])
  @@index([productId])
  @@index([isBlackMarket])
}

// Série temporelle : une ligne par variante à chaque poll de synchro.
// Permet de calculer tendances / vitesse d'épuisement sans webhooks
// Shopify. Voir docs/INSIGHTS.md.
model InventorySnapshot {
  id String @id @default(cuid())

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  quantity   Int
  recordedAt DateTime @default(now())

  @@index([variantId, recordedAt])
}

model Order {
  id        String @id @default(cuid())
  shopifyId BigInt @unique

  name String // ex: "#1054"

  // Dérivés à l'ingestion à partir des tags / statuts Shopify bruts.
  // Voir docs/SHOPIFY_SYNC.md pour la règle exacte et son historique.
  channel     OrderChannel
  isConfirmed Boolean

  tags              String[]
  financialStatus   String?
  fulfillmentStatus String?
  cancelledAt       DateTime?

  currency      String
  subtotalPrice Decimal @db.Decimal(12, 2)
  totalPrice    Decimal @db.Decimal(12, 2)

  // Dénormalisés — pas de table Customer séparée en v1 (voir
  // docs/DATABASE.md, section "Extensions futures").
  customerEmail String?
  customerName  String?
  customerPhone String?

  // LA date de référence pour tous les insights : date de commande
  // côté client, jamais une date de traitement/confirmation.
  orderCreatedAt   DateTime
  shopifyUpdatedAt DateTime
  syncedAt         DateTime @default(now())

  lineItems OrderLineItem[]

  @@index([orderCreatedAt])
  @@index([channel, orderCreatedAt])
  @@index([isConfirmed, cancelledAt])
}

model OrderLineItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Nullable : le variant peut avoir été supprimé côté Shopify après
  // la commande. On garde les valeurs brutes en secours.
  variantId         String?
  variant           Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shopifyVariantId  BigInt?
  shopifyLineItemId BigInt @unique

  sku   String?
  title String

  quantity      Int
  unitPrice     Decimal @db.Decimal(12, 2)
  totalDiscount Decimal @db.Decimal(12, 2) @default(0)

  @@index([variantId])
  @@index([orderId])
}

// Traçabilité de chaque poll de synchro : statut, curseur de reprise
// incrémentale, erreurs. Voir docs/SHOPIFY_SYNC.md.
model SyncRun {
  id String @id @default(cuid())

  resource SyncResource
  status   SyncStatus

  // Curseur de reprise : pageInfo.endCursor (backfill paginé) ou horodatage
  // updated_at (polls incrémentaux), selon le type de run.
  cursor String?

  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  recordsProcessed Int       @default(0)
  errorMessage     String?

  @@index([resource, startedAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
}

// Validation persistée d'une alerte de qualité de données/anomalie (page
// Alertes) : une fois qu'un humain a confirmé qu'une valeur surprenante est
// correcte (ex: une marge très supérieure à la moyenne, mais légitime), elle
// ne doit plus jamais réapparaître comme "à vérifier" — contrairement à un
// coût manquant qui se résout de lui-même une fois rempli côté Shopify (pas
// besoin d'acquittement pour ce cas), certaines anomalies restent vraies
// indéfiniment sans que ce soit un problème. Voir docs/INSIGHTS.md, section
// "Alertes".
model AlertAcknowledgment {
  id             String   @id @default(cuid())
  // Identifiant stable de l'alerte, ex: "missing-cost:<variantId>" ou
  // "margin-anomaly-high:<variantId>" — reconstruit à l'identique à chaque
  // calcul d'alerte pour pouvoir la retrouver ici.
  alertKey       String   @unique
  acknowledgedAt DateTime @default(now())
  acknowledgedBy String?
}

// Prévisions de ventes (page Prévisions) — deuxième exception volontaire à
// "les insights ne sont jamais stockés" (voir docs/DATABASE.md). Contrairement
// à un insight recalculable à l'identique à tout instant, une prévision est
// par nature un jugement figé au moment où elle a été faite : pour prouver
// que l'algorithme devient "de plus en plus précis" (demande explicite), il
// faut GARDER chaque prévision quotidienne telle qu'elle était ce jour-là,
// jamais l'écraser — d'où une ligne par (scope, mois cible, jour de
// génération), jamais un upsert. Voir docs/INSIGHTS.md, section "Prévisions
// de ventes".
model SalesForecast {
  id     String        @id @default(cuid())
  scope  ForecastScope
  // "GLOBAL" (sentinel non-null) ou une valeur de Product.productType.
  // Volontairement jamais null : NULL != NULL dans une contrainte @@unique
  // Postgres, donc un scopeKey nullable pour GLOBAL ne serait PAS unique en
  // pratique (plusieurs lignes GLOBAL/même mois/même jour pourraient
  // coexister sans erreur) — piège identifié avant implémentation.
  scopeKey String

  targetYear  Int
  targetMonth Int // 1-12
  // Tronqué à minuit (UTC) — un forecast par (scope, cible, jour de génération).
  generatedOn DateTime

  predictedUnits   Float
  predictedRevenue Decimal @db.Decimal(12, 2)

  // Composantes du calcul, conservées pour audit/debug (voir forecast.ts).
  baseUnitsRate   Float
  seasonalIndex   Float
  seasonalTrusted Boolean
  growthFactor    Float
  growthTrusted   Boolean

  // Renseigné une fois le mois cible clos (voir reconcileClosedMonths).
  actualUnits   Float?
  actualRevenue Decimal?  @db.Decimal(12, 2)
  reconciledAt  DateTime?

  createdAt DateTime @default(now())

  @@unique([scope, scopeKey, targetYear, targetMonth, generatedOn])
  @@index([scope, scopeKey, targetYear, targetMonth])
  @@index([generatedOn])
}
