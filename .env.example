# --- Base de données --------------------------------------------------
# En local, correspond aux identifiants du docker-compose.yml fourni.
DATABASE_URL="postgresql://freyaoms:freyaoms@localhost:5433/freyaoms?schema=public"

# --- Shopify Admin API (Custom App) ------------------------------------
# Nom de la boutique, sans ".myshopify.com" (ex: "freya-dev")
SHOPIFY_SHOP="freya-dev"
# Admin API access token de la Custom App (Admin > Apps > Develop apps)
SHOPIFY_ADMIN_API_ACCESS_TOKEN=""
# Version d'API Admin GraphQL à utiliser (voir docs/SHOPIFY_SYNC.md)
SHOPIFY_API_VERSION="2026-07"

# Fréquence de polling (minutes) — voir docs/SHOPIFY_SYNC.md pour le
# compromis fraîcheur des données / consommation du quota API.
SYNC_PRODUCTS_INTERVAL_MINUTES="60"
SYNC_ORDERS_INTERVAL_MINUTES="20"

# Secret partagé pour appeler /api/cron/sync (header "Authorization: Bearer <secret>")
CRON_SECRET=""

# --- Auth ---------------------------------------------------------------
# Générer avec: openssl rand -base64 32
AUTH_SECRET=""

# --- Seed (premier compte admin, voir prisma/seed.ts) --------------------
SEED_ADMIN_EMAIL="admin@freya.tn"
SEED_ADMIN_PASSWORD=""
